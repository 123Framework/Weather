@{
    ViewData["Title"] = "Weather AI Assistant";
}
<div class="weather-page">
    <div class="container py-5">
        <div class="text-center text-white mb-5">
            <h1 class="display-4 fw-bold">
                Weather AI Assistant
            </h1>
            <p class="lead">Прогноз погоды+ ai rec</p>
        </div>

        <div class="row justify-content-center mb-4">
            <div class="col-md-8 col-lg-6">
                <div class="card search-card shadow-lg border-0">
                    <div class="card-body p-4">
                        <form asp-controller="Weather" asp-action="Index" method="post">
                            <label class="form-label fw-semibold">Введите город</label>

                            <div class="input-group">
                                <input name="city" class="form-control form-control-lg" placeholder="Например: Moscow" required />
                                <button class="btn btn-primary btn-lg" type="submit">
                                    Узнать
                                </button>
                            </div>
                        </form>
                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger mt-3 mb-0">
                                @ViewBag.Error
                            </div>
                        }
                    </div>
                </div>
            </div>

        </div>

        @if (Model != null)
        {
            <div class="row justify-content-center">
                <div class="col-lg-10">


                    <div class="card weather-main-card shadow-lg border-0 mb-4">
                        <div class="card-body p-5 text-white">
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                                <div>
                                    <h2 class="fw-bold mb-1">@Model.City</h2>
                                    <p class="mb-0 opacity-75">@Model.Description</p>

                                </div>
                                <div class="temperature-box">
                                    @Model.Temperature C
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row g-4 mb-4">
                        <div class="col-md-4">
                            <div class="card info-card shadow border-0">
                                <div class="card-body text-center p-4">
                                    <div class="info-icon">🌡</div>
                                    <h5>Temperature</h5>
                                    <p>@Model.Temperature C</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card info-card shadow border-0">
                                <div class="card-body text-center p-4">
                                    <div class="info-icon">🌡</div>
                                    <h5>wind</h5>
                                    <p>@Model.WindSpeed m/s</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card info-card shadow border-0">
                                <div class="card-body text-center p-4">
                                    <div class="info-icon">🌡</div>
                                    <h5>Weather</h5>
                                    <p>@Model.Description</p>
                                </div>
                            </div>
                        </div>
                        <div class="card ai-card shadow-lg border-0">
                            <div class="card-body p-5">
                                <h3 class="fw-bold mb-3">AI-recommend</h3>
                                <div class="ai-text">
                                    @Html.Raw(Model.Recommendation.Replace("\n", "<br>"))
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                }
            </div>

        }
    </div>
</div>
