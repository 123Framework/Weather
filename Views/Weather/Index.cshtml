@{
    ViewData["Title"] = "Weather AI Assistant";
}
<div class="container mt-5">

    <h1 class="text-center mb-4">
        Weather AI Assistant
    </h1>
    <div class="card p-4 shadow">

        <form asp-controller="Weather" asp-action="Index" method="post">
            <div class="mb-3">
                <label class="form-label">
                    Город
                </label>
                <input name="city" class="form-control" placeholder="Введите город" />
            </div>
            <button type="submit" class="btn btn-primary">
                Узнать прогноз
            </button>
        </form>
        @if (ViewBag.Error != null){
            <div class="alert alert-danger mt-3">
                @ViewBag.Error
            </div>
        }
    </div>
    @if (Model != null){
        <div class="card shadow p-4">
            <h3>Погода в городе: @Model.City</h3>
            <p><b>Температура:</b>@Model.Temperature C</p>
            <p><b>Описание:</b>@Model.Description</p>
            <p><b>Скорость ветра:</b>@Model.WindSpeed</p>
            <hr />
            <h4>ИИ-рекомендация</h4>
            <p>@Model.Recommendation</p>

        </div>
    }
</div>